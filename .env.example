# ─── Base de datos (elige una opción) ───────────────────────────────────────
# Vercel Postgres inyecta POSTGRES_URL automáticamente al vincular la BD.
# Supabase: usa la "Connection string" (URI) en DATABASE_URL.
POSTGRES_URL=
# DATABASE_URL=

# ─── Login del panel ────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contraseña
JWT_SECRET=genera_un_string_largo_y_aleatorio_aqui

# ─── CORS (opcional en producción) ──────────────────────────────────────────
# En Vercel suele ser tu dominio, ej: https://quietud-y-belleza.vercel.app
FRONTEND_URL=http://localhost:5173

# ─── Solo desarrollo local (API en puerto 3001) ───────────────────────────────
PORT=3001
